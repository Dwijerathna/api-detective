{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run crypto_detective.mjs",
            "program": "${workspaceFolder}/crypto_detective.mjs",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run probe_detective.mjs (example)",
            "program": "${workspaceFolder}/probe_detective.mjs",
            "args": ["--url=https://api.coingecko.com/api/v3/ping", "--path=gecko_says", "--once", "--json"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
