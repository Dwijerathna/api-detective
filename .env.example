# Copy to .env and fill in (never commit .env). Loaded automatically if present.

# CoinGecko Pro (optional)
# COINGECKO_API_KEY=
# CRYPTO_DETECTIVE_COINGECKO_API_KEY=

# Crypto detective defaults (optional)
# CRYPTO_DETECTIVE_INTERVAL_SEC=60
# CRYPTO_DETECTIVE_COINS=bitcoin,ethereum
# CRYPTO_DETECTIVE_JSON=1
# CRYPTO_DETECTIVE_PRETTY=1
# CRYPTO_DETECTIVE_PLAIN=1
# CRYPTO_DETECTIVE_NO_LOG=1
# CRYPTO_DETECTIVE_DRY_RUN=1
# CRYPTO_DETECTIVE_MAX_RUNTIME_SEC=3600
# CRYPTO_DETECTIVE_JITTER_SEC=5
# CRYPTO_DETECTIVE_HISTORY_PERSIST=crypto_hist.jsonl

# Alerts
# CRYPTO_DETECTIVE_ALERT_WEBHOOK=https://example.com/hook
# ALERT_WEBHOOK_URL=
# CRYPTO_DETECTIVE_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx
# CRYPTO_DETECTIVE_NOTIFY=1

# Generic probe (optional)
# PROBE_URL=https://api.example.com/status
# PROBE_JSON_PATH=status.ok
# PROBE_INTERVAL_SEC=30
# PROBE_PRETTY=1
# PROBE_DRY_RUN=1
# PROBE_MAX_RUNTIME_SEC=3600
# PROBE_JITTER_SEC=5
# PROBE_STRICT=1
# PROBE_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx

# Web UI (npm run ui)
# CRYPTO_DETECTIVE_UI_PORT=3847
# CRYPTO_DETECTIVE_UI_HOST=127.0.0.1
# CRYPTO_DETECTIVE_UI_POLL_SEC=60

# Styling
# NO_COLOR=1
